# ─────────────────────────────────────────────────────────────────────────────
# TravelSphere — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is listed in .gitignore — it will NEVER be committed to source control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster-host>/<database>?appName=<app>
SPRING_DATA_MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/travelsphere?appName=TravelSphere-Cluster
